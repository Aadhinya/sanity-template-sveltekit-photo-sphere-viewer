{
  "name": "virtual-tour-studio",
  "private": true,
  "version": "1.1.1",
  "main": "package.json",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "sanity dev",
    "start": "sanity start",
    "build": "sanity build",
    "deploy": "sanity deploy",
    "deploy-graphql": "sanity graphql deploy",
    "format": "pnpx prettier --write \"**/*.{md,css,js,ts,json}\" \"!node_modules/**\"",
    "lint": "eslint .",
    "typegen": "sanity schema extract && sanity typegen generate"
  },
  "keywords": [
    "sanity"
  ],
  "dependencies": {
    "@sanity/vision": "^5.26.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sanity": "^5.26.0",
    "styled-components": "^6.4.2"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "^5.0.2",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "prettier": {
    "semi": false,
    "printWidth": 100,
    "bracketSpacing": false,
    "singleQuote": true
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
