{
	"name": "virtual-tour-svelte-app",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --ignore-path .gitignore --check --plugin-search-dir=. . && eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --ignore-path .gitignore --write --plugin-search-dir=. ."
	},
	"dependencies": {
		"@photo-sphere-viewer/core": "^5.14.1",
		"@photo-sphere-viewer/gallery-plugin": "^5.14.1",
		"@photo-sphere-viewer/virtual-tour-plugin": "^5.14.1",
		"@sanity/client": "^7.22.0",
		"@sanity/image-url": "^2.1.1",
		"@tailwindcss/vite": "^4.3.0",
		"groq": "^5.26.0",
		"typescript-eslint": "^8.59.4"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@portabletext/types": "^4.0.2",
		"@sanity/types": "^5.26.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@types/node": "^25.9.1",
		"@typescript-eslint/eslint-plugin": "^8.59.4",
		"@typescript-eslint/parser": "^8.59.4",
		"autoprefixer": "^10.5.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.1",
		"postcss": "^8.5.15",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^3.5.2",
		"svelte": "^5.55.8",
		"svelte-check": "^4.4.8",
		"tailwindcss": "^3.4.19",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"vite": "^7.3.3",
		"vitest": "^4.1.7"
	},
	"type": "module",
	"engines": {
		"node": ">= 14.18"
	}
}
